{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "skipLibCheck": true
  },
  "include": [
    "playwright.config.ts",
    "Fixtures/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "utilities/**/*.ts"
  ]
}
